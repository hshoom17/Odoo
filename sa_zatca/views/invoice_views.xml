<odoo>
    <data>

        <!-- Sequence -->
        <record id="seq_sa_invoice" model="ir.sequence">
            <field name="name">ZATCA Invoice</field>
            <field name="code">sa.invoice</field>
            <field name="prefix">INV/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <!-- List view -->
        <record id="view_sa_invoice_list" model="ir.ui.view">
            <field name="name">sa.invoice.list</field>
            <field name="model">sa.invoice</field>
            <field name="arch" type="xml">
                <tree decoration-success="state == 'confirmed'"
                      decoration-danger="state == 'cancelled'"
                      decoration-muted="state == 'draft'">
                    <field name="name"/>
                    <field name="invoice_date"/>
                    <field name="invoice_type"/>
                    <field name="seller_name"/>
                    <field name="buyer_name"/>
                    <field name="amount_untaxed"/>
                    <field name="amount_vat"/>
                    <field name="amount_total"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_sa_invoice_form" model="ir.ui.view">
            <field name="name">sa.invoice.form</field>
            <field name="model">sa.invoice</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" string="Confirm"
                                type="object" class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="action_submit_to_zatca" string="Submit to ZATCA"
                                type="object" class="btn-success"
                                invisible="state != 'confirmed' or zatca_status in ('cleared','reported')"/>
                        <button name="action_cancel" string="Cancel"
                                type="object"
                                invisible="state != 'confirmed'"/>
                        <button name="action_reset" string="Reset to Draft"
                                type="object"
                                invisible="state == 'draft'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirmed,cancelled"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                            <div invisible="zatca_status == 'not_submitted'">
                                <span class="badge fs-6"
                                      style="background-color: #28a745;"
                                      invisible="zatca_status not in ('cleared','reported')">
                                    ✓ ZATCA <field name="zatca_clearance" readonly="1"/>
                                </span>
                                <span class="badge fs-6"
                                      style="background-color: #dc3545;"
                                      invisible="zatca_status != 'rejected'">
                                    ✗ ZATCA REJECTED
                                </span>
                            </div>
                        </div>
                        <group>
                            <group string="Invoice Info">
                                <field name="invoice_type"/>
                                <field name="invoice_date"/>
                            </group>
                        </group>
                        <group>
                            <group string="Seller">
                                <field name="seller_name"/>
                                <field name="seller_vat"/>
                                <field name="seller_cr"/>
                                <field name="seller_address"/>
                            </group>
                            <group string="Buyer">
                                <field name="buyer_name"/>
                                <field name="buyer_vat" invisible="invoice_type == 'simplified'"/>
                                <field name="buyer_address"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lines">
                                <field name="line_ids">
                                    <tree editable="bottom">
                                        <field name="description"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"/>
                                        <field name="subtotal" readonly="1"/>
                                    </tree>
                                </field>
                                <group class="oe_subtotal_footer">
                                    <field name="amount_untaxed"/>
                                    <field name="amount_vat"/>
                                    <field name="amount_total" class="fw-bold"/>
                                </group>
                            </page>
                            <page string="QR Code">
                                <group>
                                    <field name="qr_code_image" widget="image"
                                           readonly="1" style="max-width:150px;"/>
                                </group>
                            </page>
                            <page string="Notes">
                                <field name="notes" placeholder="Additional notes..."/>
                            </page>
                            <page string="ZATCA">
                                <group string="Submission Status">
                                    <field name="zatca_status" readonly="1"/>
                                    <field name="zatca_clearance" readonly="1"
                                           invisible="not zatca_clearance"/>
                                    <field name="invoice_hash" readonly="1"
                                           invisible="not invoice_hash"/>
                                    <field name="uuid" readonly="1"/>
                                </group>
                                <group string="UBL XML" invisible="not ubl_xml">
                                    <field name="ubl_xml" readonly="1" widget="text"
                                           style="font-family:monospace; font-size:11px;"/>
                                </group>
                                <group string="ZATCA Response" invisible="not zatca_response">
                                    <field name="zatca_response" readonly="1" widget="text"
                                           style="font-family:monospace; font-size:11px;"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_sa_invoice" model="ir.actions.act_window">
            <field name="name">Invoices</field>
            <field name="res_model">sa.invoice</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
