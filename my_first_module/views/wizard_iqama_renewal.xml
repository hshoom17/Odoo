<odoo>
    <data>

        <record id="view_iqama_renewal_wizard_form" model="ir.ui.view">
            <field name="name">iqama.renewal.wizard.form</field>
            <field name="model">iqama.renewal.wizard</field>
            <field name="arch" type="xml">
                <form string="Renew Iqama">
                    <group>
                        <field name="new_expiry_date"/>
                    </group>
                    <field name="employee_ids" readonly="1">
                        <tree>
                            <field name="name"/>
                            <field name="iqama_number"/>
                            <field name="iqama_expiry" string="Current Expiry"/>
                            <field name="iqama_status"/>
                        </tree>
                    </field>
                    <footer>
                        <button name="action_renew" string="Renew" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_iqama_renewal_wizard" model="ir.actions.act_window">
            <field name="name">Renew Iqama</field>
            <field name="res_model">iqama.renewal.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_sa_employee"/>
            <field name="binding_type">action</field>
        </record>

    </data>
</odoo>
