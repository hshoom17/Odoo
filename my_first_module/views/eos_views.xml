<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── EOS record form ────────────────────────────────────────────── -->
        <record id="view_sa_eos_form" model="ir.ui.view">
            <field name="name">sa.eos.form</field>
            <field name="model">sa.eos</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_mark_paid" string="Mark as Paid"
                                type="object" class="btn-success"
                                invisible="state == 'paid'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Employee">
                                <field name="employee_id"/>
                                <field name="department_id" readonly="1"/>
                                <field name="hire_date" readonly="1"/>
                                <field name="basic_salary" readonly="1"/>
                            </group>
                            <group string="Termination">
                                <field name="last_working_day"/>
                                <field name="termination_reason"/>
                                <field name="years_of_service" readonly="1"/>
                            </group>
                        </group>
                        <group string="Gratuity Calculation">
                            <group>
                                <field name="full_gratuity" readonly="1"/>
                                <field name="gratuity_factor" readonly="1"/>
                                <field name="gratuity_amount" readonly="1"/>
                            </group>
                        </group>
                        <group string="Calculation Breakdown">
                            <field name="calculation_notes" nolabel="1" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ── EOS list ───────────────────────────────────────────────────── -->
        <record id="view_sa_eos_list" model="ir.ui.view">
            <field name="name">sa.eos.list</field>
            <field name="model">sa.eos</field>
            <field name="arch" type="xml">
                <tree decoration-success="state == 'paid'">
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="last_working_day"/>
                    <field name="termination_reason"/>
                    <field name="years_of_service"/>
                    <field name="gratuity_amount"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- ── EOS Calculator wizard ──────────────────────────────────────── -->
        <record id="view_eos_calculator_wizard" model="ir.ui.view">
            <field name="name">eos.calculator.wizard.form</field>
            <field name="model">eos.calculator.wizard</field>
            <field name="arch" type="xml">
                <form string="End of Service Calculator">
                    <sheet>
                        <field name="result_computed" invisible="1"/>
                        <group string="Employee Details">
                            <field name="employee_id"/>
                            <field name="last_working_day"/>
                            <field name="termination_reason"/>
                        </group>
                        <group string="Result" invisible="not result_computed">
                            <group>
                                <field name="years_of_service" readonly="1"/>
                                <field name="full_gratuity" readonly="1"/>
                                <field name="gratuity_factor" readonly="1"/>
                                <field name="gratuity_amount" readonly="1"/>
                            </group>
                            <group string="Breakdown">
                                <field name="calculation_notes" nolabel="1" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_calculate" string="Calculate"
                                type="object" class="btn-primary"/>
                        <button name="action_save_eos" string="Save EOS Record"
                                type="object" class="btn-success"
                                invisible="not result_computed"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- ── EOS action ─────────────────────────────────────────────────── -->
        <record id="action_sa_eos" model="ir.actions.act_window">
            <field name="name">End of Service Records</field>
            <field name="res_model">sa.eos</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="action_eos_calculator_wizard" model="ir.actions.act_window">
            <field name="name">EOS Calculator</field>
            <field name="res_model">eos.calculator.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
