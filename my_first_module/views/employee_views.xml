<odoo>
    <data>

        <record id="view_sa_employee_list" model="ir.ui.view">
            <field name="name">sa.employee.list</field>
            <field name="model">sa.employee</field>
            <field name="arch" type="xml">
                <tree decoration-danger="iqama_status == 'expired'"
                      decoration-warning="iqama_status == 'expiring'">
                    <field name="employee_number"/>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="job_title"/>
                    <field name="nationality_type"/>
                    <field name="iqama_expiry"/>
                    <field name="iqama_status"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <record id="view_sa_employee_form" model="ir.ui.view">
            <field name="name">sa.employee.form</field>
            <field name="model">sa.employee</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_activate" string="Activate"
                                type="object" class="btn-success"
                                invisible="status == 'active'"/>
                        <button name="action_suspend" string="Suspend"
                                type="object" class="btn-warning"
                                invisible="status == 'inactive'"/>
                        <field name="status" widget="statusbar"
                               statusbar_visible="active,inactive"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Employee Name"/></h1>
                            <h2><field name="employee_number" readonly="1"/></h2>
                        </div>
                        <notebook>
                            <!-- ── Tab 1: Personal & Job ───────────────────── -->
                            <page string="Personal &amp; Job">
                                <group>
                                    <group string="Personal Info">
                                        <field name="nationality_type"/>
                                        <field name="national_id"  invisible="nationality_type != 'saudi'"/>
                                        <field name="iqama_number" invisible="nationality_type != 'expat'"/>
                                        <field name="iqama_expiry" invisible="nationality_type != 'expat'"/>
                                        <field name="iqama_status" invisible="nationality_type != 'expat'" readonly="1"/>
                                    </group>
                                    <group string="Job Info">
                                        <field name="department_id"/>
                                        <field name="job_title"/>
                                        <field name="hire_date"/>
                                        <field name="salary"/>
                                        <field name="years_of_service" readonly="1"/>
                                    </group>
                                </group>
                                <!-- Probation alert -->
                                <group string="Probation Period">
                                    <group>
                                        <field name="probation_end_date"/>
                                        <field name="probation_status" readonly="1"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ── Tab 2: Contract ────────────────────────── -->
                            <page string="Contract">
                                <group>
                                    <group string="Contract Details">
                                        <field name="contract_type"/>
                                        <field name="contract_start_date"/>
                                        <field name="contract_end_date"
                                               invisible="contract_type != 'fixed_term'"/>
                                        <field name="contract_status" readonly="1"
                                               invisible="contract_type != 'fixed_term'"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ── Tab 3: Documents ───────────────────────── -->
                            <page string="Documents">
                                <group>
                                    <group string="Passport">
                                        <field name="passport_number"/>
                                        <field name="passport_expiry"/>
                                        <field name="passport_status" readonly="1"/>
                                    </group>
                                    <group string="Work Permit" invisible="nationality_type != 'expat'">
                                        <field name="work_permit_number"/>
                                        <field name="work_permit_expiry"/>
                                        <field name="work_permit_status" readonly="1"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ── Tab 4: Leave Balance ───────────────────── -->
                            <page string="Leave Balance">
                                <group>
                                    <group string="Annual Leave (Current Year)">
                                        <field name="annual_leave_entitlement" readonly="1"/>
                                        <field name="annual_leave_taken" readonly="1"/>
                                        <field name="annual_leave_balance" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sa_employee_kanban" model="ir.ui.view">
            <field name="name">sa.employee.kanban</field>
            <field name="model">sa.employee</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="job_title"/>
                    <field name="department_id"/>
                    <field name="nationality_type"/>
                    <field name="iqama_status"/>
                    <field name="status"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click
                                #{record.iqama_status.raw_value == 'expired'  ? 'border-danger'  : ''}
                                #{record.iqama_status.raw_value == 'expiring' ? 'border-warning' : ''}">
                                <div class="oe_kanban_content p-2">
                                    <strong class="d-block">
                                        <field name="name"/>
                                    </strong>
                                    <span class="text-muted">
                                        <field name="job_title"/>
                                    </span>
                                    <div class="mt-1">
                                        <field name="department_id"/>
                                    </div>
                                    <div class="mt-2 d-flex justify-content-between align-items-center">
                                        <span t-if="record.nationality_type.raw_value == 'saudi'"
                                              class="badge text-bg-success">Saudi</span>
                                        <span t-else="" class="badge text-bg-info">Expat</span>
                                        <span t-if="record.iqama_status.raw_value == 'expired'"
                                              class="badge text-bg-danger">Expired</span>
                                        <span t-if="record.iqama_status.raw_value == 'expiring'"
                                              class="badge text-bg-warning">Expiring</span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_sa_employee_search" model="ir.ui.view">
            <field name="name">sa.employee.search</field>
            <field name="model">sa.employee</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Employee"/>
                    <field name="job_title"/>
                    <field name="department_id"/>

                    <filter name="active"   string="Active"          domain="[('status','=','active')]"/>
                    <filter name="inactive" string="Inactive"        domain="[('status','=','inactive')]"/>
                    <separator/>
                    <filter name="saudi"    string="Saudi"           domain="[('nationality_type','=','saudi')]"/>
                    <filter name="expat"    string="Expat"           domain="[('nationality_type','=','expat')]"/>
                    <separator/>
                    <filter name="expired"  string="Expired Iqama"   domain="[('iqama_status','=','expired')]"/>
                    <filter name="expiring" string="Expiring Soon"   domain="[('iqama_status','=','expiring')]"/>

                    <group expand="0" string="Group By">
                        <filter name="by_department"   string="Department"   context="{'group_by': 'department_id'}"/>
                        <filter name="by_nationality"  string="Nationality"  context="{'group_by': 'nationality_type'}"/>
                        <filter name="by_status"       string="Status"       context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_deactivate_expired_iqama" model="ir.actions.server">
            <field name="name">Deactivate Expired Iqama</field>
            <field name="model_id" ref="model_sa_employee"/>
            <field name="binding_model_id" ref="model_sa_employee"/>
            <field name="binding_type">action</field>
            <field name="state">code</field>
            <field name="code">action = records.action_deactivate_expired_iqama()</field>
        </record>

        <record id="action_sa_employee" model="ir.actions.act_window">
            <field name="name">Employees</field>
            <field name="res_model">sa.employee</field>
            <field name="view_mode">tree,kanban,form</field>
        </record>

        <!-- ── Document Expiry Dashboard ──────────────────────────────────── -->
        <record id="view_sa_employee_doc_expiry_list" model="ir.ui.view">
            <field name="name">sa.employee.doc_expiry.list</field>
            <field name="model">sa.employee</field>
            <field name="arch" type="xml">
                <tree decoration-danger="iqama_status == 'expired' or passport_status == 'expired' or work_permit_status == 'expired' or contract_status == 'expired'"
                      decoration-warning="iqama_status == 'expiring' or passport_status == 'expiring' or work_permit_status == 'expiring' or contract_status == 'expiring' or probation_status == 'expiring'">
                    <field name="name"/>
                    <field name="nationality_type"/>
                    <field name="department_id"/>
                    <field name="iqama_expiry" optional="show"/>
                    <field name="iqama_status" optional="show"/>
                    <field name="passport_expiry" optional="show"/>
                    <field name="passport_status" optional="show"/>
                    <field name="work_permit_expiry" optional="show"/>
                    <field name="work_permit_status" optional="show"/>
                    <field name="contract_end_date" optional="show"/>
                    <field name="contract_status" optional="show"/>
                    <field name="probation_end_date" optional="show"/>
                    <field name="probation_status" optional="show"/>
                </tree>
            </field>
        </record>

        <record id="action_doc_expiry_dashboard" model="ir.actions.act_window">
            <field name="name">Document Expiry Dashboard</field>
            <field name="res_model">sa.employee</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_sa_employee_doc_expiry_list"/>
            <field name="domain">[
                '|', '|', '|', '|',
                ('iqama_status', 'in', ['expiring', 'expired']),
                ('passport_status', 'in', ['expiring', 'expired']),
                ('work_permit_status', 'in', ['expiring', 'expired']),
                ('contract_status', 'in', ['expiring', 'expired']),
                ('probation_status', '=', 'expiring')
            ]</field>
            <field name="context">{'search_default_status': 'active'}</field>
        </record>

    </data>
</odoo>
